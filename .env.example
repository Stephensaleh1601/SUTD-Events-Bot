# Copy this file to .env and fill in your own values.
# Never commit your real .env file.

# Telegram bot token, created via @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# The Telegram channel/group the bot reads events from.
# Must be a public username with @ (the bot matches on chat.username) -
# the bot must be a member/admin of this group to receive its messages.
TARGET_CHAT=@your_telegram_channel

# API key for the Agnes AI service (https://agnes-ai.com), used by agnes_ai.py
# to extract structured event data from raw chat text.
AGNES_API_KEY=your_agnes_api_key_here

# Optional: override the Agnes AI model or API base URL (defaults shown below)
# AGNES_MODEL=agnes-2.0-flash
# AGNES_API_BASE=https://apihub.agnes-ai.com/v1

# Optional: override the local SQLite database filename
DB_NAME=events_hub.db
