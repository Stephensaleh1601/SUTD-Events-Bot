# Copy this file to .env and fill in your own values.
# Never commit your real .env file.

# Telegram bot token, created via @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# The Telegram channel/group the bot reads events from
# (public username with @, or a numeric chat ID)
TARGET_CHAT=@your_telegram_channel

# Telegram user-account API credentials, from https://my.telegram.org
# Needed by Telethon to read message history / listen for new messages
TG_API_ID=your_api_id
TG_API_HASH=your_api_hash

# The phone number (with country code) of the Telegram account used to log in
TG_PHONE=+10000000000

# Only needed if that account has two-factor authentication enabled
TG_2FA_PASSWORD=your_2fa_password_if_any

# API key for the Agnes AI service used to extract structured event data
AGNES_API_KEY=your_agnes_api_key_here

# Optional: override the local SQLite database filename
DB_NAME=events_hub.db
